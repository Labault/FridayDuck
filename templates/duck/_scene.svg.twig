<svg
  id="duck-scene"
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 800 540"
  preserveAspectRatio="xMidYMid meet"
  role="img"
  aria-labelledby="duck-title duck-description"
>
  <title id="duck-title">Le canard du vendredi</title>
  <desc id="duck-description">
    Tibec, le canard développeur, assis dans son bureau : grosse tête crème, large
    bec orange, lunettes rondes, capuche turquoise au symbole du code, pieds palmés
    et tasse de café. Derrière lui, un triple écran, une fenêtre avec vue sur le
    Puy de Dôme, un siège ergonomique, clavier/souris et des goodies de dev
    (éléphant PHP, baleine Docker, manchot Linux). Endormi, des « Zzz » s'envolent.
  </desc>

  <!-- Palette Tibec (charte « Canard Dev ») : crème #FFF7EE · turquoise #2CB7C2
      · corail #FF7F6A · orange bec #F4A62A · contour chaud #6B5440. -->
  <defs>
    <linearGradient id="grad-hoodie" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0" stop-color="#3CC4CE" />
      <stop offset="1" stop-color="#1E9AA6" />
    </linearGradient>
    <linearGradient id="grad-beak" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0" stop-color="#FBC15E" />
      <stop offset="1" stop-color="#EE9620" />
    </linearGradient>
    <linearGradient id="grad-foot" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0" stop-color="#F4A62A" />
      <stop offset="1" stop-color="#E58A14" />
    </linearGradient>
    <radialGradient id="grad-head" cx="42%" cy="32%" r="74%">
      <stop offset="0" stop-color="#FFFDF8" />
      <stop offset="1" stop-color="#F4E6D2" />
    </radialGradient>
    <radialGradient id="grad-cheek" cx="50%" cy="50%" r="50%">
      <stop offset="0" stop-color="#FF9B86" stop-opacity="0.6" />
      <stop offset="1" stop-color="#FF9B86" stop-opacity="0" />
    </radialGradient>
    <linearGradient id="grad-wall" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0" stop-color="#EEF5F6" />
      <stop offset="1" stop-color="#E2ECEE" />
    </linearGradient>
    <linearGradient id="grad-sky" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0" stop-color="#CDEBF8" />
      <stop offset="1" stop-color="#EAF7FB" />
    </linearGradient>
    <linearGradient id="grad-wood" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0" stop-color="#D2A878" />
      <stop offset="1" stop-color="#BC8E5E" />
    </linearGradient>
  </defs>

  <!-- ════════════════ DÉCOR : bureau de dev (derrière le canard) ════════════════ -->
  <g id="scene-background">
    <!-- Mur + plinthe + sol. -->
    <rect x="0" y="0" width="800" height="432" fill="url(#grad-wall)" />
    <rect x="0" y="426" width="800" height="8" fill="#D6C6AE" />
    <rect x="0" y="432" width="800" height="108" fill="#E4D6BF" />
    <g stroke="#D3C1A4" stroke-width="2" opacity="0.6">
      <path d="M 180 432 L 150 540" /><path d="M 380 432 L 360 540" /><path d="M 560 432 L 588 540" /><path d="M 720 432 L 752 540" />
    </g>

    <!-- Grande fenêtre : vue sur le Puy de Dôme (élément régional mis en avant). -->
    <rect x="26" y="34" width="300" height="274" rx="14" fill="#F8F5EF" stroke="#CBBDA6" stroke-width="7" />
    <rect x="40" y="48" width="272" height="246" rx="6" fill="url(#grad-sky)" />
    <!-- soleil + nuages -->
    <circle cx="86" cy="98" r="22" fill="#FFE6A6" />
    <ellipse cx="250" cy="92" rx="42" ry="15" fill="#FFFFFF" opacity="0.85" />
    <ellipse cx="206" cy="126" rx="30" ry="11" fill="#FFFFFF" opacity="0.7" />
    <!-- Chaîne des Puys (arrière-plan). -->
    <path d="M 40 294 L 40 256 C 70 242 96 248 112 262 C 134 240 160 246 178 264 C 202 242 236 248 256 264 C 280 250 300 256 312 262 L 312 294 Z" fill="#A8CF88" />
    <!-- Le Puy de Dôme : grand dôme volcanique arrondi, deux tons. -->
    <path d="M 44 294 C 56 214 120 120 184 120 C 248 120 304 210 312 294 Z" fill="#8CBB66" />
    <path d="M 184 120 C 120 120 56 214 44 294 L 184 294 Z" fill="#9DC878" />
    <!-- Chemin panoramique en lacets. -->
    <path d="M 84 288 q 56 -10 78 -46 q 14 -26 -14 -40" fill="none" stroke="#CDE0AE" stroke-width="4" stroke-linecap="round" opacity="0.85" />
    <!-- Temple de Mercure : ruines gallo-romaines, à gauche du sommet. -->
    <g fill="#DACEB6" stroke="#B9A988" stroke-width="1.5">
      <rect x="120" y="118" width="46" height="7" rx="1" />
      <rect x="124" y="96" width="6" height="22" /><rect x="135" y="92" width="6" height="26" />
      <rect x="146" y="98" width="6" height="20" /><rect x="157" y="94" width="6" height="24" />
      <rect x="121" y="88" width="24" height="6" />
    </g>
    <!-- Antenne du Puy de Dôme : pylône en treillis (silhouette réelle). -->
    <g>
      <path d="M 196 122 L 206 72 L 212 72 L 222 122 Z" fill="#C2C9D2" />
      <g stroke="#8A929E" stroke-width="2" stroke-linecap="round" fill="none">
        <path d="M 199 110 L 219 110 M 201 98 L 217 98 M 203 86 L 215 86 M 205 78 L 213 78" />
        <path d="M 196 122 L 217 110 M 222 122 L 201 110 M 201 110 L 215 98 M 217 110 L 203 98 M 203 98 L 213 86 M 215 98 L 205 86" />
      </g>
      <path d="M 209 72 L 209 56" stroke="#8A929E" stroke-width="2.5" stroke-linecap="round" />
      <circle cx="209" cy="55" r="3.5" fill="#E5564B" />
    </g>
    <!-- liseré d'herbe. -->
    <path d="M 40 294 C 110 282 170 286 312 294 L 312 296 L 40 296 Z" fill="#73A352" opacity="0.7" />
    <!-- meneaux + appui. -->
    <line x1="244" y1="48" x2="244" y2="294" stroke="#F8F5EF" stroke-width="7" />
    <line x1="40" y1="178" x2="312" y2="178" stroke="#F8F5EF" stroke-width="7" />
    <rect x="16" y="304" width="320" height="13" rx="4" fill="#E4DAC6" />

    <!-- Bureau (plateau, à droite). -->
    <rect x="322" y="250" width="478" height="34" rx="8" fill="url(#grad-wood)" />
    <rect x="322" y="284" width="478" height="12" rx="4" fill="#A87C50" />

    <!-- Triple écran (décor secondaire), entièrement à droite du canard. -->
    <g>
      <g fill="#3A3F47">
        <rect x="522" y="240" width="13" height="14" /><rect x="509" y="248" width="40" height="8" rx="3" />
        <rect x="624" y="238" width="13" height="16" /><rect x="611" y="248" width="40" height="8" rx="3" />
        <rect x="726" y="240" width="13" height="14" /><rect x="713" y="248" width="40" height="8" rx="3" />
      </g>
      <!-- écran gauche (code) -->
      <rect x="486" y="156" width="98" height="94" rx="6" fill="#23272E" />
      <rect x="492" y="162" width="86" height="82" rx="3" fill="#1E2A38" />
      <g stroke-linecap="round" stroke-width="4">
        <path d="M 500 176 h 22" stroke="#FF7F6A" /><path d="M 528 176 h 34" stroke="#5FD0D8" />
        <path d="M 506 190 h 44" stroke="#9DE07A" /><path d="M 500 204 h 20" stroke="#FFD98A" />
        <path d="M 506 218 h 50" stroke="#7FB6F2" /><path d="M 500 232 h 32" stroke="#9DE07A" />
      </g>
      <!-- écran central (terminal) -->
      <rect x="588" y="152" width="100" height="98" rx="6" fill="#23272E" />
      <rect x="594" y="158" width="88" height="86" rx="3" fill="#0E1B12" />
      <g fill="#36d27a" font-family="monospace" font-size="11">
        <text x="600" y="176">$ git push</text>
        <text x="600" y="194">deploy ✓</text>
        <text x="600" y="212">friday 16:58</text>
      </g>
      <path d="M 600 226 h 11" stroke="#36d27a" stroke-width="4" stroke-linecap="round" />
      <!-- écran droit (navigateur) -->
      <rect x="692" y="156" width="98" height="94" rx="6" fill="#23272E" />
      <rect x="698" y="162" width="86" height="82" rx="3" fill="#F4F7FA" />
      <rect x="698" y="162" width="86" height="14" rx="3" fill="#D9E2EA" />
      <circle cx="707" cy="169" r="2.4" fill="#FF7F6A" /><circle cx="715" cy="169" r="2.4" fill="#FFD98A" /><circle cx="723" cy="169" r="2.4" fill="#9DE07A" />
      <g stroke-linecap="round" stroke-width="4">
        <path d="M 706 192 h 40" stroke="#7FB6F2" /><path d="M 706 206 h 70" stroke="#D2DBE3" />
        <path d="M 706 220 h 54" stroke="#D2DBE3" /><path d="M 706 234 h 74" stroke="#2CB7C2" />
      </g>

      <!-- Figurine Tux (manchot Linux) sur l'écran gauche. -->
      <g transform="translate(512 100)">
        <ellipse cx="22" cy="40" rx="20" ry="24" fill="#1c1c1c" />
        <ellipse cx="22" cy="44" rx="12" ry="16" fill="#FFFFFF" />
        <circle cx="22" cy="20" r="15" fill="#1c1c1c" />
        <ellipse cx="16" cy="20" rx="4" ry="5" fill="#FFFFFF" /><ellipse cx="28" cy="20" rx="4" ry="5" fill="#FFFFFF" />
        <circle cx="16" cy="21" r="2" fill="#1c1c1c" /><circle cx="28" cy="21" r="2" fill="#1c1c1c" />
        <path d="M 16 27 q 6 6 12 0 q -6 4 -12 0 Z" fill="#F4A62A" />
        <path d="M 10 60 l 13 0 l -4 8 l -13 0 Z" fill="#F4A62A" /><path d="M 24 60 l 13 0 l 4 8 l -13 0 Z" fill="#F4A62A" />
      </g>

      <!-- Figurine baleine Docker sur l'écran droit. -->
      <g transform="translate(700 98)">
        <path d="M 8 36 C 8 18 30 12 48 16 C 60 18 72 24 80 34 C 70 44 50 48 34 46 C 20 44 10 42 8 36 Z" fill="#2496ED" />
        <g fill="#2bb0ff" stroke="#1f86d6" stroke-width="1.5">
          <rect x="30" y="2" width="12" height="11" /><rect x="44" y="2" width="12" height="11" /><rect x="37" y="-10" width="12" height="11" />
        </g>
        <path d="M 80 34 q 12 -2 16 6 q -10 2 -16 -2 Z" fill="#2496ED" />
        <circle cx="22" cy="30" r="3" fill="#0d3a63" />
        <path d="M 14 46 q -8 4 -12 -2 q 8 0 12 2 Z" fill="#2496ED" />
      </g>
    </g>

    <!-- Clavier + souris Logitech sur le plateau (devant les écrans). -->
    <g>
      <rect x="512" y="258" width="150" height="30" rx="7" fill="#3A3F47" />
      <rect x="512" y="258" width="150" height="30" rx="7" fill="#2C3036" opacity="0.4" />
      <g fill="#23262B">
        <rect x="520" y="264" width="12" height="7" rx="2" /><rect x="536" y="264" width="12" height="7" rx="2" />
        <rect x="552" y="264" width="12" height="7" rx="2" /><rect x="568" y="264" width="12" height="7" rx="2" />
        <rect x="584" y="264" width="12" height="7" rx="2" /><rect x="600" y="264" width="12" height="7" rx="2" />
        <rect x="616" y="264" width="12" height="7" rx="2" /><rect x="632" y="264" width="12" height="7" rx="2" />
        <rect x="648" y="264" width="8" height="7" rx="2" />
        <rect x="532" y="276" width="104" height="7" rx="2" />
      </g>
      <path d="M 678 260 C 698 260 708 270 708 283 C 708 292 698 292 678 292 C 668 292 668 260 678 260 Z" fill="#3A3F47" />
      <line x1="688" y1="264" x2="688" y2="276" stroke="#23262B" stroke-width="2.5" stroke-linecap="round" />
    </g>

    <!-- ElePHPant (la mascotte PHP), posé au sol à gauche, redessiné. -->
    <g>
      <ellipse cx="112" cy="392" rx="56" ry="46" fill="#8892BF" />
      <rect x="86" y="406" width="26" height="32" rx="11" fill="#7C86B2" />
      <rect x="120" y="406" width="26" height="32" rx="11" fill="#7C86B2" />
      <ellipse cx="99" cy="438" rx="16" ry="7" fill="#6B739E" /><ellipse cx="133" cy="438" rx="16" ry="7" fill="#6B739E" />
      <circle cx="74" cy="360" r="40" fill="#8892BF" />
      <ellipse cx="86" cy="356" rx="26" ry="32" fill="#7C86B2" />
      <ellipse cx="88" cy="356" rx="15" ry="21" fill="#9BA1CA" />
      <path d="M 44 358 C 26 368 26 400 40 418 C 49 428 63 426 61 414 C 51 410 47 394 55 384 C 61 376 59 364 51 358 Z" fill="#8892BF" />
      <path d="M 50 392 q -8 8 -2 18" stroke="#F4EFE2" stroke-width="4" fill="none" stroke-linecap="round" />
      <circle cx="70" cy="352" r="5" fill="#2b2f55" /><circle cx="72" cy="350" r="1.7" fill="#FFFFFF" />
      <path d="M 70 322 q 6 -10 14 -6" stroke="#6B739E" stroke-width="4" fill="none" stroke-linecap="round" />
    </g>

    <!-- Siège ergonomique (dossier + têtière + accoudoirs), derrière le canard. -->
    <g>
      <rect x="352" y="158" width="96" height="44" rx="22" fill="#4F5864" />
      <rect x="330" y="190" width="140" height="262" rx="30" fill="#5A6470" />
      <rect x="340" y="204" width="120" height="232" rx="24" fill="#48515C" opacity="0.55" />
      <g stroke="#3E4651" stroke-width="2" opacity="0.5">
        <path d="M 360 228 v 196" /><path d="M 388 228 v 204" /><path d="M 414 228 v 204" /><path d="M 440 228 v 196" />
      </g>
      <rect x="312" y="356" width="26" height="74" rx="12" fill="#3E4651" />
      <rect x="462" y="356" width="26" height="74" rx="12" fill="#3E4651" />
    </g>
  </g>

  <!-- ════════════════ CANARD (réduit pour laisser respirer le décor) ════════════════ -->
  <g id="duck-stage" transform="translate(232 135) scale(0.42)">
    <g id="duck-shadow">
      <ellipse cx="400" cy="772" rx="186" ry="24" fill="#3b2f24" opacity="0.18" />
    </g>

    <!-- Halo du pulse global (§18.3) : piloté par le rig, masqué au repos. -->
    <g id="duck-halo" opacity="0">
      <circle cx="400" cy="380" r="300" fill="#ffd98a" />
    </g>

    <g id="duck-root">
      <!-- ── Corps : capuche turquoise (hoodie signature de Tibec). ──────────── -->
      <g id="duck-body">
        <!-- Capuche repliée derrière la nuque (dépasse de chaque côté du cou). -->
        <path d="M 304 432 Q 360 408 400 414 L 400 472 Q 338 472 310 496 Z" fill="#16838E" />
        <path d="M 496 432 Q 440 408 400 414 L 400 472 Q 462 472 490 496 Z" fill="#16838E" />

        <!-- Cou crème reliant la tête au corps. -->
        <path d="M 366 404 L 434 404 L 428 462 L 372 462 Z" fill="#F5E7D3" stroke="#6B5440" stroke-width="3" />

        <!-- Torse compact (canard assis). -->
        <path
          d="M 400 440 C 470 440 516 466 534 512 C 552 560 550 648 540 706 C 538 720 506 728 400 728 C 294 728 262 720 260 706 C 250 648 248 560 266 512 C 284 466 330 440 400 440 Z"
          fill="url(#grad-hoodie)" stroke="#15808B" stroke-width="4"
        />
        <!-- Lumière douce sur le torse. -->
        <path d="M 312 478 C 294 542 294 630 310 700 C 282 684 270 608 276 526 C 280 498 296 482 312 478 Z" fill="#5FD0D8" opacity="0.5" />

        <!-- Ourlet côtelé bas. -->
        <path d="M 268 702 Q 400 730 532 702 L 532 722 Q 400 748 268 722 Z" fill="#16838E" />
        <g stroke="#0F6E78" stroke-width="3" opacity="0.55">
          <path d="M 320 708 l 0 18" /><path d="M 360 712 l 0 20" /><path d="M 400 714 l 0 20" />
          <path d="M 440 712 l 0 20" /><path d="M 480 708 l 0 18" />
        </g>

        <!-- Col / ouverture de capuche autour du cou. -->
        <path d="M 332 446 Q 400 496 468 446 Q 460 472 400 480 Q 340 472 332 446 Z" fill="#15808B" />
        <path d="M 344 452 Q 400 492 456 452 Q 450 472 400 478 Q 350 472 344 452 Z" fill="#0F6E78" opacity="0.8" />

        <!-- Cordons de capuche + embouts. -->
        <path d="M 384 470 C 380 512 380 540 382 560" fill="none" stroke="#FFFFFF" stroke-width="8" stroke-linecap="round" />
        <path d="M 416 470 C 420 512 420 542 418 562" fill="none" stroke="#FFFFFF" stroke-width="8" stroke-linecap="round" />
        <circle cx="382" cy="564" r="7" fill="#F3F3EF" />
        <circle cx="418" cy="566" r="7" fill="#F3F3EF" />

        <!-- Poche kangourou + surpiqûre. -->
        <path d="M 322 614 Q 400 646 478 614 L 470 678 Q 400 698 330 678 Z" fill="#0F6E78" opacity="0.4" />
        <path d="M 330 618 Q 400 648 470 618" fill="none" stroke="#0F6E78" stroke-width="2.5" opacity="0.6" />

        <!-- Logo </> sur la poitrine (signature). -->
        <g fill="none" stroke="#FFFFFF" stroke-width="10" stroke-linecap="round" stroke-linejoin="round">
          <path d="M 372 566 L 350 590 L 372 614" />
          <path d="M 428 566 L 450 590 L 428 614" />
          <path d="M 414 558 L 386 622" />
        </g>
      </g>

      <!-- ── Pieds palmés visibles (canard assis, on voit le dessous des palmes). ── -->
      <g id="duck-feet">
        <g stroke="#D9831A" stroke-width="3.5" stroke-linejoin="round">
          <path d="M 352 760 C 322 758 306 740 310 720 C 314 710 390 710 394 720 C 398 740 382 758 352 760 Z" fill="url(#grad-foot)" />
          <path d="M 448 760 C 478 758 494 740 490 720 C 486 710 410 710 406 720 C 402 740 418 758 448 760 Z" fill="url(#grad-foot)" />
        </g>
        <ellipse cx="352" cy="740" rx="30" ry="18" fill="#FBD89A" opacity="0.65" />
        <ellipse cx="448" cy="740" rx="30" ry="18" fill="#FBD89A" opacity="0.65" />
        <g stroke="#D9831A" stroke-width="3" stroke-linecap="round" opacity="0.8">
          <path d="M 334 718 L 336 752" /><path d="M 370 718 L 368 752" />
          <path d="M 466 718 L 464 752" /><path d="M 430 718 L 432 752" />
        </g>
      </g>

      <!-- ── Ailes / manches (l'aile gauche tient la tasse, la droite repose). ── -->
      <g id="duck-left-wing">
        <path d="M 320 452 C 286 470 266 524 270 586 C 272 618 294 634 320 626 C 308 562 312 498 334 466 Z" fill="url(#grad-hoodie)" stroke="#15808B" stroke-width="4" />
        <g fill="none" stroke="#15808B" stroke-width="2.5" opacity="0.5">
          <path d="M 296 500 q 14 8 26 4" /><path d="M 290 536 q 14 8 28 4" /><path d="M 288 572 q 14 8 28 4" />
        </g>
        <path d="M 272 600 q 24 16 52 6 l -4 26 q -24 8 -44 -4 Z" fill="#16838E" />
        <ellipse cx="298" cy="640" rx="42" ry="38" fill="#FFF7EE" stroke="#6B5440" stroke-width="3.5" />
      </g>
      <g id="duck-right-wing">
        <path d="M 480 452 C 514 470 534 524 530 586 C 528 618 506 634 480 626 C 492 562 488 498 466 466 Z" fill="url(#grad-hoodie)" stroke="#15808B" stroke-width="4" />
        <g fill="none" stroke="#15808B" stroke-width="2.5" opacity="0.5">
          <path d="M 504 500 q -14 8 -26 4" /><path d="M 510 536 q -14 8 -28 4" /><path d="M 512 572 q -14 8 -28 4" />
        </g>
        <path d="M 528 600 q -24 16 -52 6 l 4 26 q 24 8 44 -4 Z" fill="#16838E" />
        <ellipse cx="502" cy="640" rx="42" ry="38" fill="#FFF7EE" stroke="#6B5440" stroke-width="3.5" />
        <g fill="none" stroke="#6B5440" stroke-width="2.5" opacity="0.55">
          <path d="M 490 632 q 8 10 6 22" /><path d="M 506 630 q 6 10 4 22" />
        </g>
        <path d="M 520 612 q 18 -8 24 10 q 4 16 -12 20 Z" fill="#FFF7EE" stroke="#6B5440" stroke-width="3" />
      </g>

      <g id="duck-head">
        <!-- Houppette : trois plumes rondes balayées vers l'arrière. -->
        <g fill="url(#grad-head)" stroke="#6B5440" stroke-width="3.5" stroke-linejoin="round">
          <path d="M 372 144 C 348 124 332 98 340 74 C 366 90 384 118 392 144 Z" />
          <path d="M 392 140 C 384 100 392 64 410 50 C 426 84 418 116 412 142 Z" />
          <path d="M 412 144 C 420 110 444 86 470 86 C 456 112 436 128 428 146 Z" />
        </g>

        <!-- Crâne : grosse tête ronde et lisse. -->
        <path
          d="M 400 120 C 306 120 238 192 238 276 C 238 362 306 422 400 424 C 494 422 562 362 562 276 C 562 192 494 120 400 120 Z"
          fill="url(#grad-head)" stroke="#6B5440" stroke-width="4"
        />
        <!-- Reflet doux en haut du crâne (volume). -->
        <ellipse cx="346" cy="188" rx="74" ry="34" fill="#FFFFFF" opacity="0.35" />

        <!-- Joues rosées. -->
        <ellipse cx="310" cy="306" rx="30" ry="21" fill="url(#grad-cheek)" />
        <ellipse cx="490" cy="306" rx="30" ry="21" fill="url(#grad-cheek)" />

        <!-- Yeux : grands, brillants (blanc + pupille ; la paupière crème ferme l'œil au clignement). -->
        <g id="duck-left-eye">
          <circle cx="352" cy="250" r="34" fill="#ffffff" stroke="#2F3540" stroke-width="3" />
          <g id="duck-left-pupil">
            <circle cx="356" cy="254" r="18" fill="#2F3540" />
            <circle cx="364" cy="246" r="7" fill="#ffffff" />
            <circle cx="350" cy="262" r="3.5" fill="#ffffff" opacity="0.85" />
          </g>
          <g id="duck-left-eyelid">
            <rect x="314" y="212" width="76" height="76" rx="24" fill="#FBEFDD" />
          </g>
        </g>

        <g id="duck-right-eye">
          <circle cx="448" cy="250" r="34" fill="#ffffff" stroke="#2F3540" stroke-width="3" />
          <g id="duck-right-pupil">
            <circle cx="444" cy="254" r="18" fill="#2F3540" />
            <circle cx="452" cy="246" r="7" fill="#ffffff" />
            <circle cx="438" cy="262" r="3.5" fill="#ffffff" opacity="0.85" />
          </g>
          <g id="duck-right-eyelid">
            <rect x="410" y="212" width="76" height="76" rx="24" fill="#FBEFDD" />
          </g>
        </g>

        <!-- Large bec de canard en relief ; s'ouvre (scaleY) au café. -->
