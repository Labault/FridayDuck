# Le Canard du Vendredi — contrat des variables d'environnement de PRODUCTION.
#
# Ce fichier DOCUMENTE ce que l'image prod attend au RUNTIME. Il n'est PAS lu par
# l'application : il sert de modèle au fichier de secrets `.env.prod.local`
# (gitignoré) que `deploy.sh` passe à Docker Compose via `--env-file` pour
# interpoler `compose.prod.yaml`. C'est de l'injection au runtime sur le VPS —
# RIEN n'est gravé dans l'image (§31.4, §27.6).
#
# NB : nommé `.env.prod.dist` (pas `.env.dist`) À DESSEIN — Symfony charge
# automatiquement un `.env.dist` comme valeurs par défaut quand `.env` est absent,
# ce qui polluerait un boot hors `prod` (e2e/preprod) avec ces valeurs. Symfony ne
# charge JAMAIS de `.env.<env>.dist` : ce nom est donc neutre côté application.
#
# Sur le VPS (une seule fois) :
#     cp .env.prod.dist .env.prod.local   # puis renseigner les SECRETS ci-dessous
#     chmod 600 .env.prod.local           # ne JAMAIS committer (couvert par .gitignore)
#
# Légende :  [SECRET] = secret, injecté runtime, jamais committé / jamais dans l'image.
#            [PUBLIC] = non sensible, valeur connue.
#            [BUILD]  = fourni à la construction de l'image (ARG), pas au runtime.

# ─── Cadre applicatif ────────────────────────────────────────────────────────
# APP_ENV est FIGÉ dans l'image (`.env.local.php` compilé par `composer dump-env
# prod`) — ne PAS le redéfinir ici. APP_DEBUG=0 en découle.

# [SECRET] Clé de signature interne Symfony. Générer une valeur aléatoire :
#          `php -r 'echo bin2hex(random_bytes(16)), PHP_EOL;'`
APP_SECRET=

# [BUILD] Version exposée par /health et annotée dans Grafana. `deploy.sh` la
#         dérive de git (`git describe --tags --always`) → ARG APP_VERSION.
#         Inutile de la fixer ici.
APP_VERSION=

# [PUBLIC] Génération d'URLs hors contexte HTTP (CLI, Scheduler, liens absolus).
DEFAULT_URI=https://canard.labault.dev

# ─── Reverse-proxy / TLS (Caddy, co-localisé FrankenPHP) ─────────────────────
# [PUBLIC] Domaine public servi. Caddy provisionne automatiquement le certificat
#          Let's Encrypt pour ce nom (volume caddy_data = persistance des certifs).
#          compose.prod.yaml y ajoute le vhost interne `app:80` (HTTP, Mercure).
SERVER_NAME=canard.labault.dev

# ─── Base de données (PostgreSQL) ────────────────────────────────────────────
# [SECRET] DSN complet (contient le mot de passe). L'hôte est le service compose
#          `database`. Garder serverVersion aligné sur l'image (17).
DATABASE_URL=postgresql://app:CHANGE_ME@database:5432/app?serverVersion=17&charset=utf8
# [SECRET] Mot de passe du conteneur PostgreSQL — DOIT correspondre à DATABASE_URL.
POSTGRES_PASSWORD=CHANGE_ME
# [PUBLIC] Nom de base et utilisateur (doivent matcher DATABASE_URL).
POSTGRES_DB=app
POSTGRES_USER=app

# ─── Temps réel (Mercure, hub co-localisé dans le process Caddy/FrankenPHP) ───
# [PUBLIC] URL INTERNE de publication, utilisée par l'app et le worker (vhost
#          `app:80`, HTTP, pas de TLS — boucle interne au réseau compose).
MERCURE_URL=http://app/.well-known/mercure
# [PUBLIC] URL PUBLIQUE HTTPS RÉELLE jointe par l'EventSource du navigateur.
#          ⚠️ DOIT être l'URL externe joignable depuis Internet — JAMAIS un nom
#          de service interne (le piège exact rencontré en e2e).
MERCURE_PUBLIC_URL=https://canard.labault.dev/.well-known/mercure
# [SECRET] Secret de signature des JWT Mercure. Symfony signe (publish), le hub
#          Caddy vérifie. Les trois variables partagent le même secret.
#          Générer : `php -r 'echo bin2hex(random_bytes(32)), PHP_EOL;'`
MERCURE_JWT_SECRET=CHANGE_ME
MERCURE_PUBLISHER_JWT_KEY=CHANGE_ME
MERCURE_SUBSCRIBER_JWT_KEY=CHANGE_ME

# ─── Messagerie asynchrone (Messenger) ───────────────────────────────────────
# [PUBLIC] Transport par défaut : table Doctrine (consommée par le service worker).
MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0

# ─── Observabilité (OpenTelemetry) ───────────────────────────────────────────
# [PUBLIC] VIDE = télémétrie DÉSACTIVÉE (providers no-op). Le déploiement du
#          Collector sur le VPS arrive à la phase suivante.
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=friday-duck

# ─── INTERDIT EN PRODUCTION ──────────────────────────────────────────────────
# APP_FAKE_NOW falsifie l'horloge métier (§7.4). Il NE DOIT PAS exister en prod :
# absent de l'image (non figé par dump-env) ET absent d'ici. L'environnement
# `prod` le neutralise de toute façon (FakeClockProductionGuard), mais on ne lui
# laisse même pas l'occasion. Ne PAS décommenter.
# APP_FAKE_NOW=
