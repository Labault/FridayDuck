{
  "name": "friday-duck-assets",
  "type": "module",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "e2e": "playwright test",
    "e2e:up": "npm run build && docker compose -f compose.e2e.yaml up -d --build --wait",
    "e2e:down": "docker compose -f compose.e2e.yaml down -v"
  },
  "dependencies": {
    "@hotwired/stimulus": "^3.2.2",
    "@theatre/core": "^0.7.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@symfony/stimulus-bridge": "^3.2.0 || ^4.0.0",
    "@theatre/studio": "^0.7.2",
    "happy-dom": "^20.0.0",
    "typescript": "^5.7.0",
    "vite": "^8.1.0",
    "vite-plugin-symfony": "^8.2.4",
    "vitest": "^2.1.0"
  }
}
