# Le Canard du Vendredi — exemple de configuration d'environnement.
#
# Copiez ce fichier en `.env` (ignoré par git) puis ajustez les valeurs :
#     cp .env.example .env
#
# DO NOT DEFINE PRODUCTION SECRETS IN A COMMITTED FILE.
# En production, utilisez les variables d'environnement réelles ou les secrets
# Symfony : https://symfony.com/doc/current/configuration/secrets.html

###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=
APP_SHARE_DIR=var/share
# Version applicative exposée par /health et l'image prod (§31.4). Renseignée à
# la construction de l'image (ARG APP_VERSION) ; vide en local = « dev ».
APP_VERSION=
###< symfony/framework-bundle ###

###> friday-duck / simulation temporelle (§7.4) ###
# Le SERVEUR est l'unique source de vérité temporelle (§7.1). En dev et en
# préproduction, APP_FAKE_NOW gèle l'horloge métier pour simuler un vendredi.
# Format ISO-8601 avec décalage explicite (fuseau métier : Europe/Paris).
#
#   APP_FAKE_NOW=2026-07-03T10:30:00+02:00
#
# Laisser VIDE = utiliser l'heure système réelle.
# ⚠️ INTERDIT / À NEUTRALISER EN PRODUCTION : doit rester vide (ou absent) en
#    prod. Son usage est visible dans la barre de debug, journalisé et testé.
APP_FAKE_NOW=
###< friday-duck / simulation temporelle ###

###> symfony/routing ###
# Génération d'URLs hors contexte HTTP (commandes CLI, Scheduler).
DEFAULT_URI=http://localhost
###< symfony/routing ###

###> doctrine/doctrine-bundle ###
# PostgreSQL (§5, §22.4). En stack Docker, l'hôte est le service `database` de
# compose.yaml (réseau interne) ; hors Docker, remplacez par 127.0.0.1 dans
# votre .env.local. Le `serverVersion` suit POSTGRES_VERSION (17).
# Format : https://www.doctrine-project.org/projects/doctrine-dbal/en/latest/reference/configuration.html#connecting-using-a-url
DATABASE_URL="postgresql://app:!ChangeMe!@database:5432/app?serverVersion=17&charset=utf8"
###< doctrine/doctrine-bundle ###

###> symfony/mercure-bundle ###
# Hub Mercure (§20), CO-LOCALISÉ dans le process Caddy/FrankenPHP — pas de
# conteneur dédié (§21).
# URL INTERNE de publication, utilisée par l'app Symfony (vhost `app:80`, HTTP).
MERCURE_URL=http://app/.well-known/mercure
# URL PUBLIQUE du hub, utilisée par le navigateur pour s'abonner (EventSource).
MERCURE_PUBLIC_URL=https://localhost/.well-known/mercure
# Secret de signature des JWT Mercure — à remplacer, ne jamais committer en clair.
MERCURE_JWT_SECRET="!ChangeThisMercureHubJWTSecretKey!"
###< symfony/mercure-bundle ###

###> symfony/messenger ###
# Transport Messenger (§25). Par défaut : table Doctrine.
# MESSENGER_TRANSPORT_DSN=amqp://guest:guest@localhost:5672/%2f/messages
# MESSENGER_TRANSPORT_DSN=redis://localhost:6379/messages
MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0
###< symfony/messenger ###

###> open-telemetry (Phase 7a, §26) ###
# Endpoint OTLP/HTTP du Collector (base, sans /v1/...). VIDE = télémétrie
# DÉSACTIVÉE (providers no-op). Le stack Collector/Grafana arrive en 7b.
OTEL_EXPORTER_OTLP_ENDPOINT=
# Nom de service dans les traces/métriques (défaut applicatif : friday-duck).
OTEL_SERVICE_NAME=friday-duck
###< open-telemetry ###
# Niveau des diagnostics internes du SDK OTel (none|error|warning|info|debug).
OTEL_LOG_LEVEL=error
