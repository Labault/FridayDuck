<?xml version="1.0" encoding="UTF-8"?>
<doctrine-mapping xmlns="http://doctrine-project.org/schemas/orm/doctrine-mapping"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  xsi:schemaLocation="http://doctrine-project.org/schemas/orm/doctrine-mapping
                  https://www.doctrine-project.org/schemas/orm/doctrine-mapping.xsd">
    <!-- Mapping EXTERNE (§30) : l'entité Domaine reste PHP pur, sans attribut Doctrine. -->
    <entity name="App\Domain\Friday\FridayEdition" table="friday_edition">
        <id name="id" type="string" length="26">
            <generator strategy="NONE"/>
        </id>
        <field name="fridayDate" column="friday_date" type="date_immutable"/>
        <field name="timezone" type="string" length="64"/>
        <field name="editionStatus" column="status" type="string" length="16" enum-type="App\Domain\Friday\EditionStatus"/>
        <field name="energy" type="integer"/>
        <field name="energyVersion" column="energy_version" type="integer"/>
        <field name="coffeeTarget" column="coffee_target" type="integer"/>
        <field name="coffeeCount" column="coffee_count" type="integer"/>
        <field name="overcaffeinationCount" column="overcaffeination_count" type="integer"/>
        <field name="createdAt" column="created_at" type="datetime_immutable"/>
        <field name="closedAt" column="closed_at" type="datetime_immutable" nullable="true"/>
        <!-- Vote (§10) : séquence de résultats (anti-régression, DISTINCTE d'energy_version)
            et gagnant figé après 14:00 (immuable). -->
        <field name="resultsSequence" column="results_sequence" type="integer"/>
        <field name="winnerAccessoryCode" column="winner_accessory_code" type="string" length="64" nullable="true"/>
        <!-- Conseil (§11) : conseil du jour figé (immuable), séquence d'advice
            (DISTINCTE), et compteurs de réactions dénormalisés par type. -->
        <field name="adviceId" column="advice_id" type="string" length="26" nullable="true"/>
        <field name="adviceSequence" column="advice_sequence" type="integer"/>
        <field name="concerningCount" column="concerning_count" type="integer"/>
        <field name="alreadyDoneCount" column="already_done_count" type="integer"/>
        <field name="takingNotesCount" column="taking_notes_count" type="integer"/>
        <unique-constraints>
            <unique-constraint name="uniq_friday_edition_date_tz" columns="friday_date,timezone"/>
        </unique-constraints>
    </entity>
</doctrine-mapping>
