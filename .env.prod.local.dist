# Le Canard du Vendredi — modèle des SECRETS / variables de PRODUCTION.
#
# Ce fichier DOCUMENTE ce que `compose.prod.yaml` attend pour s'interpoler sur le
# VPS. Il n'est PAS lu par l'application : il sert de modèle au fichier réel
# `.env.prod.local` (gitignoré) que `deploy.sh` passe à Docker Compose via
# `--env-file`. C'est de l'injection au RUNTIME — RIEN n'est gravé dans l'image
# (§31.4, §27.6). Nommage aligné sur le VPS (cf. Red Flag Bingo).
#
# Sur le VPS (une seule fois) :
#     cp .env.prod.local.dist .env.prod.local   # puis renseigner les SECRETS
#     chmod 600 .env.prod.local                  # ne JAMAIS committer (.gitignore)
#
# Légende :  [SECRET] = secret, injecté runtime, jamais committé / jamais dans l'image.
#            [PUBLIC] = non sensible, valeur connue.
#            [BUILD]  = fourni à la construction de l'image (ARG), pas au runtime.

# ─── Cadre applicatif ────────────────────────────────────────────────────────
# APP_ENV est FIGÉ dans l'image (`.env.local.php` compilé par `composer dump-env
# prod`) — ne PAS le redéfinir ici. APP_DEBUG=0 en découle.

# [SECRET] Clé de signature interne Symfony. Générer une valeur aléatoire :
#          `php -r 'echo bin2hex(random_bytes(16)), PHP_EOL;'`  (ou `openssl rand -hex 32`)
APP_SECRET=

# [BUILD] Version exposée par /health et annotée dans Grafana. `deploy.sh` la
#         dérive de git (`git describe --tags --always`) → ARG APP_VERSION.
#         Inutile de la fixer ici.
#APP_VERSION=

# ─── Domaine public (TLS terminé par le Caddy GLOBAL externe) ────────────────
# [PUBLIC] SOURCE UNIQUE du nom public, SANS https:// ni slash final.
#          compose.prod.yaml en dérive DEFAULT_URI (https://$APP_DOMAIN) et
#          MERCURE_PUBLIC_URL (https://$APP_DOMAIN/.well-known/mercure).
#          ⚠️ L'app NE gère PAS le TLS : pas de LETSENCRYPT_EMAIL ici, c'est le
#          Caddy global du VPS qui provisionne le certificat de ce domaine.
APP_DOMAIN=tibec.labault.dev

# ─── Base de données (PostgreSQL) ────────────────────────────────────────────
# [SECRET] DSN complet (contient le mot de passe). L'hôte est le service compose
#          `database`. Garder serverVersion aligné sur l'image (17).
DATABASE_URL=postgresql://app:CHANGE_ME@database:5432/app?serverVersion=17&charset=utf8
# [SECRET] Mot de passe du conteneur PostgreSQL — DOIT correspondre à DATABASE_URL.
POSTGRES_PASSWORD=CHANGE_ME
# [PUBLIC] Nom de base et utilisateur (doivent matcher DATABASE_URL).
POSTGRES_DB=app
POSTGRES_USER=app

# ─── Temps réel (Mercure, hub co-localisé dans le process Caddy/FrankenPHP) ───
# NB : MERCURE_URL (publication interne, http://app/.well-known/mercure) et
#      MERCURE_PUBLIC_URL (dérivée d'APP_DOMAIN) ont des défauts dans compose ;
#      inutile de les répéter ici. Seuls les SECRETS de signature sont requis.
# [SECRET] Secret de signature des JWT Mercure. Symfony signe (publish), le hub
#          Caddy vérifie. Les trois variables partagent le même secret.
#          Générer : `php -r 'echo bin2hex(random_bytes(32)), PHP_EOL;'`
MERCURE_JWT_SECRET=CHANGE_ME
MERCURE_PUBLISHER_JWT_KEY=CHANGE_ME
MERCURE_SUBSCRIBER_JWT_KEY=CHANGE_ME

# ─── Messagerie asynchrone (Messenger) ───────────────────────────────────────
# [PUBLIC] Transport par défaut : table Doctrine (consommée par worker + relay).
#          Défaut dans compose ; surcharge ici seulement si besoin.
#MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0

# ─── Observabilité (OpenTelemetry) ───────────────────────────────────────────
# [PUBLIC] Endpoint du Collector du stack d'obs prod (compose.observability.prod.yaml),
#          joint via le réseau Docker partagé `observability`. HTTP sur 4318 (l'image
#          n'embarque PAS l'ext gRPC PHP — l'exporter OTLP parle HTTP/protobuf). VIDE
#          = télémétrie désactivée (providers no-op) : rollback en une variable.
#          Prérequis : `docker network create observability` + stack d'obs démarré.
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
OTEL_SERVICE_NAME=friday-duck

# ─── INTERDIT EN PRODUCTION ──────────────────────────────────────────────────
# APP_FAKE_NOW falsifie l'horloge métier (§7.4). Il NE DOIT PAS exister en prod :
# absent de l'image (non figé par dump-env) ET absent d'ici. L'environnement
# `prod` le neutralise de toute façon (FakeClockProductionGuard), mais on ne lui
# laisse même pas l'occasion. Ne PAS décommenter.
# APP_FAKE_NOW=
