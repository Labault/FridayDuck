# Le Canard du Vendredi — SECRETS & config des sauvegardes (§37.4).
#
# Modèle de l'EnvironmentFile root-only chargé par les units systemd. Sur le VPS :
#     install.sh le copie en /etc/canard-backup/backup.env (chmod 600, root:root).
# JAMAIS committé, JAMAIS dans une unit. C'est le PENDANT de .env.prod.local pour
# le backup : l'app a ses secrets, le backup a les siens, aucune collision.
#
# NB : AUCUN credential PostgreSQL ici. pg_dump lit $POSTGRES_USER / $POSTGRES_DB
#      DANS le conteneur duck_db (socket local). Le mot de passe DB ne quitte
#      jamais le conteneur — surface d'attaque réduite.

# ─── Dépôt restic (Storage Box Hetzner, backend SFTP) ────────────────────────
# Alias SSH défini dans /root/.ssh/config (cf. README.md) : restic y trouve hôte,
# port (23), utilisateur et clé dédiée. Le chemin est un sous-dossier du Storage Box.
RESTIC_REPOSITORY=sftp:canard-storagebox:/canard-restic

# [SECRET] LA clé de voûte. Si tu la perds, TOUS les backups sont irrécupérables
#          (chiffré illisible). À stocker AUSSI hors-serveur (gestionnaire de mots
#          de passe). Générer : openssl rand -base64 48
RESTIC_PASSWORD=CHANGE_ME
# Alternative plus propre : pointer un fichier root-only au lieu de la valeur en clair.
# RESTIC_PASSWORD_FILE=/etc/canard-backup/restic-password

# ─── Base à sauvegarder ──────────────────────────────────────────────────────
DB_CONTAINER=duck_db
# Plancher anti-dump-vide (octets). Un dump réel de cette base dépasse largement ;
# en dessous → snapshot rejeté. Relever quand la base aura grossi.
MIN_DUMP_BYTES=2000

# ─── Rétention (imposée) ─────────────────────────────────────────────────────
RESTIC_KEEP_DAILY=7
RESTIC_KEEP_WEEKLY=4

# ─── Test de restauration (cible jetable) ────────────────────────────────────
RESTORE_TEST_IMAGE=postgres:17-alpine
# Vérif post-restore. Défaut : ≥ 1 table publique. Cibler une table métier plus tard :
# VERIFY_QUERY=SELECT count(*) FROM coffee
# VERIFY_MIN=1

# ─── Alerte & dead-man's-switch (optionnels mais recommandés) ────────────────
# healthchecks.io (free tier) : crée un check « daily », colle son ping URL ici.
# Le succès pingue l'URL nue, l'échec /fail, le début /start. HC alerte AUSSI si
# aucun ping n'arrive dans la fenêtre → attrape « le timer ne s'est jamais lancé ».
HEALTHCHECK_PING_URL=
# Check d'intégrité hebdo (un second check healthchecks.io, période « weekly »).
HEALTHCHECK_CHECK_PING_URL=
# Test de restauration mensuel (un troisième check, période « monthly »).
HEALTHCHECK_RESTORE_PING_URL=
# Receiver générique alternatif (prioritaire sur HEALTHCHECK_PING_URL pour l'alerte
# OnFailure). POST {"text": "..."} — Slack/Discord/ntfy/webhook maison.
ALERT_WEBHOOK=
